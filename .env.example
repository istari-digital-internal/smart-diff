# ── LLM Provider ──────────────────────────────────────────────
# Options: openai | gemini | claude
LLM_PROVIDER=openai

# ── API Keys (fill in the one you are using) ──────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# ── Model overrides (optional) ────────────────────────────────
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro
CLAUDE_MODEL=claude-opus-4-8
